<view class="page">
  <view class="card header">
    <view class="title">好友对战</view>
    <view class="subtitle" wx:if="{{cloudReady}}">
      实时在线匹配 · 当前昵称 {{player.name}}
    </view>
    <view class="subtitle" wx:else>{{cloudTip}}</view>
  </view>

  <view class="card stage" wx:if="{{cloudReady && phase === 'lobby'}}">
    <view class="section-title">选择难度</view>
    <view class="difficulty-list">
      <view
        class="difficulty-chip {{difficulty === item.key ? 'active' : ''}}"
        wx:for="{{difficultyList}}"
        wx:key="key"
        data-key="{{item.key}}"
        bindtap="selectDifficulty"
      >
        {{item.name}}
      </view>
    </view>
    <view class="actions">
      <button class="primary-btn action-btn" bindtap="quickMatch">快速匹配</button>
      <button class="ghost-btn action-btn" bindtap="createInviteRoom">创建房间邀请好友</button>
      <button class="ghost-btn action-btn" bindtap="refreshOnline">刷新在线列表</button>
    </view>
    <view class="online-title">在线玩家</view>
    <view class="online-row" wx:for="{{onlinePlayers}}" wx:key="id">
      <text>{{item.name}}</text>
      <view class="online-right">
        <text class="muted">{{item.roomCode ? ('房间 ' + item.roomCode) : '大厅中'}}</text>
        <button
          class="mini-invite"
          data-name="{{item.name}}"
          bindtap="inviteFromList"
        >
          邀请PK
        </button>
      </view>
    </view>
    <view class="muted tips">{{tips}}</view>
  </view>

  <view class="card stage center" wx:if="{{cloudReady && phase === 'waiting'}}">
    <view class="section-title">等待对手加入</view>
    <view class="room-code">{{roomCode}}</view>
    <view class="muted">把邀请卡片发给好友，好友打开即可进入同一房间。</view>
    <button class="primary-btn btn" open-type="share" wx:if="{{canShare}}">邀请好友 PK</button>
    <button class="ghost-btn btn" bindtap="leaveToLobby">返回大厅</button>
  </view>

  <view class="card stage" wx:if="{{cloudReady && phase === 'memory'}}">
    <view class="count">{{memoryLeft}}s</view>
    <view class="muted">对手：{{opponentName}}</view>
    <view class="muted">双方同时记忆算式</view>
    <view class="memory-list">
      <view class="memory-item" wx:for="{{questions}}" wx:key="id">{{item.expression}}</view>
    </view>
  </view>

  <view class="card stage" wx:if="{{cloudReady && phase === 'answer'}}">
    <view class="row-between">
      <view class="timer">剩余 {{answerLeft}}s</view>
      <view class="muted">{{currentIndex + 1}} / {{questions.length}}</view>
    </view>
    <view class="muted rival">对手：{{opponentName}}</view>
    <view class="progress-group">
      <view class="progress-item">
        <view class="name">我方进度</view>
        <view class="bar">
          <view class="inner self" style="width: {{selfProgress}}%;"></view>
        </view>
      </view>
      <view class="progress-item">
        <view class="name">对手进度</view>
        <view class="bar">
          <view class="inner rival" style="width: {{rivalProgress}}%;"></view>
        </view>
      </view>
    </view>
    <view class="expression">{{currentExpression}}</view>
    <view class="answer-box">{{inputValue || '输入答案'}}</view>
    <view class="muted tips">{{tips}}</view>
    <number-pad
      bind:input="onPadInput"
      bind:delete="onPadDelete"
      bind:clear="onPadClear"
      bind:submit="onPadSubmit"
      confirm-text="确认作答"
    />
  </view>

  <view class="card stage" wx:if="{{cloudReady && phase === 'result' && result}}">
    <view class="section-title">
      {{result.draw ? '平局' : (result.win ? '对战获胜' : '对战失败')}}
    </view>
    <view class="row">
      <text class="muted">答对题数</text>
      <text>{{result.correctCount}} / {{result.totalCount}}</text>
    </view>
    <view class="row">
      <text class="muted">对手答对</text>
      <text>{{result.rivalCorrect}} / {{result.totalCount}}</text>
    </view>
    <view class="row">
      <text class="muted">积分奖励</text>
      <text>+{{result.points}}</text>
    </view>
    <view class="row">
      <text class="muted">我的用时</text>
      <text>{{result.userTime}}</text>
    </view>
    <button class="primary-btn btn" bindtap="playAgain">再来一局</button>
    <button class="ghost-btn btn" bindtap="leaveToLobby">返回大厅</button>
    <button class="ghost-btn btn" bindtap="toHome">回首页</button>
  </view>

  <view class="card stage center" wx:if="{{!cloudReady}}">
    <view class="section-title">实时对战不可用</view>
    <view class="muted">{{cloudTip}}</view>
    <button class="ghost-btn btn" bindtap="toHome">回首页</button>
  </view>
</view>
