<view class="page">
  <view class="card hero">
    <view class="section-title">极速冲榜</view>
    <view class="muted">固定 6 题进阶算式，答得越快分越高</view>
    <view class="best">
      我的最高分：<text class="score">{{profile.bestSpeedScore || 0}}</text>
    </view>
    <button class="primary-btn" bindtap="toSpeed">去冲榜</button>
  </view>

  <view class="tabs card">
    <view class="tab {{tab === 'global' ? 'active' : ''}}" data-tab="global" bindtap="switchTab">
      全网榜
    </view>
    <view class="tab {{tab === 'friend' ? 'active' : ''}}" data-tab="friend" bindtap="switchTab">
      好友榜
    </view>
  </view>

  <view class="card list-card">
    <view class="rank-row header">
      <text>排名</text>
      <text>玩家</text>
      <text>分数</text>
      <text>用时</text>
    </view>
    <view class="rank-row {{item.isSelf ? 'self' : ''}}" wx:for="{{displayList}}" wx:key="id">
      <text>{{item.rank}}</text>
      <text>{{item.name}}</text>
      <text>{{item.score}}</text>
      <text>{{item.timeText}}</text>
    </view>
  </view>
</view>
