.summary {
  padding: 28rpx;
  margin-bottom: 18rpx;
  background: linear-gradient(135deg, #effcf3 0%, #ffffff 100%);
}

.title {
  text-align: center;
  font-size: 42rpx;
  font-weight: 700;
  color: #14532d;
}

.subtitle {
  margin-top: 8rpx;
  text-align: center;
  color: #6b7280;
  font-size: 26rpx;
}

.metrics {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.metric {
  background: #ffffff;
  border-radius: 16rpx;
  text-align: center;
  padding: 16rpx 10rpx;
}

.metric-label {
  color: #6b7280;
  font-size: 22rpx;
}

.metric-value {
  margin-top: 8rpx;
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 600;
}

.rewards {
  padding: 24rpx;
  margin-bottom: 18rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 28rpx;
  padding: 10rpx 0;
}

.new-title {
  margin-top: 16rpx;
  background: #fef3c7;
  color: #92400e;
  border-radius: 14rpx;
  padding: 12rpx 14rpx;
  font-size: 25rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.empty {
  padding: 40rpx 24rpx;
  text-align: center;
}
